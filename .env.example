# AgoraMesh Local Development Environment
# Copy this file to .env and adjust values as needed.
#
#   cp .env.example .env

# ── Node ─────────────────────────────────────────────────────────────────────
# API token for authenticating requests to the node
AGORAMESH_API_TOKEN=dev-token-change-me

# Log level: trace, debug, info, warn, error
RUST_LOG=debug

# CORS origins (comma-separated)
AGORAMESH_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Node identity
AGORAMESH_NODE_DID=did:agoramesh:local:dev-node
AGORAMESH_NODE_NAME=AgoraMesh Dev Node

# ── Bridge ───────────────────────────────────────────────────────────────────
# API token for the bridge service
BRIDGE_API_TOKEN=dev-bridge-token

# CORS origins for the bridge
BRIDGE_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Agent private key (hex, without 0x prefix). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Leave empty to skip on-chain features.
BRIDGE_AGENT_PRIVATE_KEY=

# ── Blockchain (Base Sepolia testnet) ────────────────────────────────────────
RPC_URL=https://sepolia.base.org
CHAIN_ID=84532
PROVIDER_DID=did:agoramesh:local:dev-agent
