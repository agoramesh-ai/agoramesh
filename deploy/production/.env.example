# AgoraMesh Production Environment Configuration
#
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# NEVER commit the .env file to version control.
# All values below are placeholders — replace them before deploying.

# API token for authenticating requests to the AgoraMesh node
AGORAMESH_API_TOKEN=change-me-node-api-token

# API token for authenticating requests to the bridge
BRIDGE_API_TOKEN=change-me-bridge-api-token

# Ethereum private key for the bridge agent (used for signing transactions)
# Must start with 0x followed by 64 hex characters
#
# PREFERRED: Use Docker secrets instead of this env var.
# Place the key in ./secrets/agent_private_key and it will be mounted
# at /run/secrets/agent_private_key inside the container.
# See setup.sh for instructions.
BRIDGE_AGENT_PRIVATE_KEY=0x_REPLACE_WITH_REAL_PRIVATE_KEY
